{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "librarian": {
      "model": "zhipuai-coding-plan/glm-5-turbo",
      "fallback_models": [
        "openai/gpt-5.4-mini-fast",
        "kimi-for-coding/k2p6"
      ]
    },
    "explore": {
      "model": "zhipuai-coding-plan/glm-5-turbo",
      "fallback_models": [
        "openai/gpt-5.4-mini-fast",
        "kimi-for-coding/k2p6"
      ]
    },
    "multimodal-looker": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        {
          "model": "google/antigravity-gemini-3.1-flash",
          "variant": "medium"
        }
      ]
    },
    "prometheus": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "atlas": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        {
          "model": "google/antigravity-gemini-3.1-pro",
          "variant": "high"
        }
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "artistry": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        {
          "model": "google/antigravity-gemini-3.1-pro",
          "variant": "high"
        }
      ]
    },
    "quick": {
      "model": "zhipuai-coding-plan/glm-5.1",
      "fallback_models": [
        "kimi-for-coding/k2p6"
      ]
    },
    "unspecified-low": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "unspecified-high": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        {
          "model": "openai/gpt-5.4",
          "variant": "high"
        }
      ]
    },
    "writing": {
      "model": "kimi-for-coding/k2p6",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5.1",
        {
          "model": "google/antigravity-gemini-3.1-flash",
          "variant": "medium"
        }
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "openai": 3,
      "google": 5,
      "kimi-for-coding": 3,
      "zhipuai-coding-plan": 5
    },
    "modelConcurrency": {
      "openai/gpt-5.4": 2,
      "openai/gpt-5.4-mini-fast": 8,
      "kimi-for-coding/k2p6": 3,
      "zhipuai-coding-plan/glm-5-turbo": 5
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "notify_on_fallback": true
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  }
}
