# Shell integration: push terminfo and env vars over SSH
shell-integration-features = ssh-terminfo,ssh-env

# Hide mouse cursor while typing, reappears on mouse movement
mouse-hide-while-typing = true

# Strip trailing whitespace when copying to clipboard
clipboard-trim-trailing-spaces = true

# Primary font family
font-family = 0xProto Nerd Font Mono

# Font size in points
font-size = 18

# Thicker font strokes on macOS Retina displays for better readability
# font-thicken = true

# CJK font mapping: use LXGW WenKai Mono for Chinese characters and symbols
# U+4E00-U+9FFF  CJK Unified Ideographs (basic)
# U+3400-U+4DBF  CJK Unified Ideographs Extension A
# U+FF00-U+FFEF  Fullwidth Forms (fullwidth punctuation, letters, etc.)
# U+3000-U+303F  CJK Symbols and Punctuation (。、「」 etc.)
# U+2E80-U+2EFF  CJK Radicals Supplement
font-codepoint-map = U+4E00-U+9FFF,U+3400-U+4DBF,U+FF00-U+FFEF,U+3000-U+303F,U+2E80-U+2EFF=LXGW WenKai Mono Medium

# Increase line height slightly for better readability
adjust-cell-height = 1

# Color theme
theme = Catppuccin Mocha

# Minimum foreground/background contrast ratio to prevent invisible text
minimum-contrast = 1.1

# Cursor style: bar pairs well with vim (auto-switches to block in normal mode)
cursor-style = bar

# Merge tabs into titlebar to save vertical space (macOS)
macos-titlebar-style = tabs

# Content padding (in points)
window-padding-x = 4
window-padding-y = 2,0

# Initial window size in terminal grid cells
window-width = 80
window-height = 25

# Restore window position and size across restarts (macOS)
window-save-state = default

# Slight background transparency with blur (macOS)
background-opacity = 0.95
background-blur = 20

# Load machine-specific overrides if present
# config-file = ?config.local
