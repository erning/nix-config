#!/usr/bin/env bash

set -euo pipefail

language=auto
pi_args=()

while (($# > 0)); do
    case "$1" in
        --language)
            if (($# < 2)); then
                printf 'translate: --language requires auto, en, or zh\n' >&2
                exit 2
            fi

            language="$2"
            shift 2
            ;;
        --language=*)
            language="${1#--language=}"
            shift
            ;;
        --)
            shift
            pi_args+=("$@")
            break
            ;;
        *)
            pi_args+=("$1")
            shift
            ;;
    esac
done

case "$language" in
    auto)
        system_prompt=$(
            cat <<'PROMPT'
You are a concise translation router.

Rules:
- If the input is Chinese-language text, translate the full meaning into
  natural English.
- If the input mixes Chinese-language text with any other language, translate
  the full meaning into natural English.
- If the input is not Chinese-language text, translate the full meaning into
  natural Simplified Chinese. This includes English, German, Japanese, Korean,
  French, and other non-Chinese languages.
- Treat Japanese text as non-Chinese even when it contains kanji.
- Preserve names, code, paths, commands, URLs, numbers, and quoted text unless
  translation is clearly needed.
- Return only the translation. Do not include explanations, notes, quotes, or
  extra formatting.
PROMPT
        )
        ;;
    en)
        system_prompt=$(
            cat <<'PROMPT'
You are a concise translator.

Rules:
- Translate the full meaning of the input into natural English, regardless of
  the input language.
- Preserve names, code, paths, commands, URLs, numbers, and quoted text unless
  translation is clearly needed.
- Return only the translation. Do not include explanations, notes, quotes, or
  extra formatting.
PROMPT
        )
        ;;
    zh)
        system_prompt=$(
            cat <<'PROMPT'
You are a concise translator.

Rules:
- Translate the full meaning of the input into natural Simplified Chinese,
  regardless of the input language.
- Preserve names, code, paths, commands, URLs, numbers, and quoted text unless
  translation is clearly needed.
- Return only the translation. Do not include explanations, notes, quotes, or
  extra formatting.
PROMPT
        )
        ;;
    *)
        printf 'translate: invalid --language: %s\n' "$language" >&2
        printf 'translate: expected one of: auto, en, zh\n' >&2
        exit 2
        ;;
esac

has_provider=false
has_model=false

for arg in "${pi_args[@]}"; do
    case "$arg" in
        --provider | --provider=*)
            has_provider=true
            ;;
        --model | --model=*)
            has_model=true
            ;;
    esac
done

default_args=()

if [[ "$has_provider" == false ]]; then
    default_args+=(--provider kimi-coding)
fi

if [[ "$has_model" == false ]]; then
    default_args+=(--model k2p7)
fi

exec pi -p \
    "${default_args[@]}" \
    --offline \
    --no-session \
    --no-tools \
    --no-context-files \
    --no-skills \
    --no-extensions \
    --no-prompt-templates \
    --no-themes \
    --no-approve \
    --thinking off \
    --system-prompt "$system_prompt" \
    "${pi_args[@]}"
